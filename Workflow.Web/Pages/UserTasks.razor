@page "/tasks"
@inject WorkflowApiClient Api

<PageTitle>Aufgaben</PageTitle>

<h1>Aufgaben</h1>

@if (_loading)
{
    <p>Laden...</p>
}
else if (_tasks.Length == 0)
{
    <div class="alert alert-info">Keine offenen Aufgaben.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Titel</th>
                <th>Workflow</th>
                <th>Zugewiesen an</th>
                <th>Erstellt</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in _tasks)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.WorkflowInstanceId[..8]...</td>
                    <td>@(task.AssignedTo ?? "-")</td>
                    <td>@task.CreatedAt.ToString("g")</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-success" @onclick="() => Complete(task, true)">Genehmigen</button>
                            <button class="btn btn-danger" @onclick="() => Complete(task, false)">Ablehnen</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_activeTask is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_approving ? "Genehmigen" : "Ablehnen"): @_activeTask.Title</h5>
                </div>
                <div class="modal-body">
                    @if (_activeTask.Description is not null)
                    {
                        <p>@_activeTask.Description</p>
                    }
                    <div class="mb-3">
                        <label class="form-label">Kommentar (optional)</label>
                        <textarea class="form-control" @bind="_comment" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelAction">Abbrechen</button>
                    <button class="btn @(_approving ? "btn-success" : "btn-danger")" @onclick="ConfirmAction">
                        @(_approving ? "Genehmigen" : "Ablehnen")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private UserTaskDto[] _tasks = [];
    private UserTaskDto? _activeTask;
    private bool _approving;
    private string _comment = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        _loading = true;
        try
        {
            _tasks = await Api.GetTasksAsync();
        }
        catch
        {
            _tasks = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void Complete(UserTaskDto task, bool approve)
    {
        _activeTask = task;
        _approving = approve;
        _comment = "";
    }

    private void CancelAction()
    {
        _activeTask = null;
        _comment = "";
    }

    private async Task ConfirmAction()
    {
        if (_activeTask is null) return;

        var data = string.IsNullOrWhiteSpace(_comment)
            ? null
            : new Dictionary<string, object?> { ["comment"] = _comment };

        var status = _approving ? "Approved" : "Rejected";
        await Api.CompleteTaskAsync(_activeTask.Id, new CompleteTaskDto(status, data));
        _activeTask = null;
        _comment = "";
        await LoadTasks();
    }
}
