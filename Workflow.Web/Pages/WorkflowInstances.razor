@page "/instances"
@page "/instances/{Id}"
@inject WorkflowApiClient Api
@inject NavigationManager Navigation

<PageTitle>Instanzen</PageTitle>

@if (Id is not null)
{
    @* Detail view *@
    <div class="d-flex align-items-center gap-2 mb-3">
        <button class="btn btn-sm btn-outline-secondary" @onclick="BackToList">Zurück</button>
        <h1 class="mb-0">Instanz @Id[..8]...</h1>
    </div>

    @if (_selectedInstance is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle text-muted">Status</h6>
                        <span class="badge @GetStatusBadgeClass(_selectedInstance.Status) fs-6 mt-1">@_selectedInstance.Status</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle text-muted">Gestartet</h6>
                        <p class="card-text mt-1">@_selectedInstance.CreatedAt.ToString("G")</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-subtitle text-muted">Abgeschlossen</h6>
                        <p class="card-text mt-1">@(_selectedInstance.CompletedAt?.ToString("G") ?? "-")</p>
                    </div>
                </div>
            </div>
        </div>

        @if (_selectedInstance.Error is not null)
        {
            <div class="alert alert-danger">@_selectedInstance.Error</div>
        }

        <h4>Execution Log</h4>
        @if (_executionLog.Length > 0)
        {
            <div class="timeline">
                @foreach (var log in _executionLog)
                {
                    <div class="timeline-item">
                        <div class="d-flex justify-content-between">
                            <strong>@log.ActivityId (@log.ActivityType)</strong>
                            <span class="badge @GetLogStatusBadgeClass(log.Status)">@log.Status</span>
                        </div>
                        <small class="text-muted">@log.StartedAt.ToString("T") - @(log.CompletedAt?.ToString("T") ?? "...")</small>
                        @if (log.Error is not null)
                        {
                            <div class="text-danger small">@log.Error</div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">Kein Log vorhanden.</p>
        }
    }
}
else
{
    @* List view *@
    <h1>Workflow-Instanzen</h1>

    <div class="mb-3">
        <label class="form-label">Filter nach Status:</label>
        <select class="form-select form-select-sm" style="width: 200px" @bind="_statusFilter">
            <option value="">Alle</option>
            <option value="Running">Running</option>
            <option value="Suspended">Suspended</option>
            <option value="Completed">Completed</option>
            <option value="Faulted">Faulted</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>

    @if (_loading)
    {
        <p>Laden...</p>
    }
    else if (FilteredInstances.Length == 0)
    {
        <div class="alert alert-info">Keine Instanzen vorhanden.</div>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Workflow</th>
                    <th>Status</th>
                    <th>Gestartet</th>
                    <th>Abgeschlossen</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var instance in FilteredInstances)
                {
                    <tr>
                        <td>@instance.WorkflowDefinitionId[..8]...</td>
                        <td><span class="badge @GetStatusBadgeClass(instance.Status)">@instance.Status</span></td>
                        <td>@instance.CreatedAt.ToString("g")</td>
                        <td>@(instance.CompletedAt?.ToString("g") ?? "-")</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" @onclick="() => ShowDetails(instance.Id)">Details</button>
                                @if (instance.Status is "Running" or "Suspended")
                                {
                                    <button class="btn btn-outline-danger" @onclick="() => Cancel(instance.Id)">Abbrechen</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public string? Id { get; set; }

    private bool _loading = true;
    private WorkflowInstanceDto[] _instances = [];
    private WorkflowInstanceDto? _selectedInstance;
    private ActivityExecutionLogDto[] _executionLog = [];
    private string _statusFilter = "";

    private WorkflowInstanceDto[] FilteredInstances =>
        string.IsNullOrEmpty(_statusFilter)
            ? _instances
            : _instances.Where(i => i.Status == _statusFilter).ToArray();

    protected override async Task OnParametersSetAsync()
    {
        if (Id is not null)
        {
            _selectedInstance = await Api.GetInstanceAsync(Id);
            _executionLog = await Api.GetInstanceLogAsync(Id);
        }
        else
        {
            await LoadInstances();
        }
    }

    private async Task LoadInstances()
    {
        _loading = true;
        try
        {
            _instances = await Api.GetInstancesAsync();
        }
        catch
        {
            _instances = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowDetails(string id) =>
        Navigation.NavigateTo($"/instances/{id}");

    private void BackToList() => Navigation.NavigateTo("/instances");

    private async Task Cancel(string id)
    {
        await Api.CancelInstanceAsync(id);
        await LoadInstances();
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Running" => "bg-primary",
        "Suspended" => "bg-warning text-dark",
        "Completed" => "bg-success",
        "Faulted" => "bg-danger",
        "Cancelled" => "bg-secondary",
        _ => "bg-info"
    };

    private static string GetLogStatusBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "Running" => "bg-primary",
        "Faulted" => "bg-danger",
        "Suspended" => "bg-warning text-dark",
        "Skipped" => "bg-secondary",
        _ => "bg-info"
    };
}
