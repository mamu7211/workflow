@using System.Globalization

@{
    var sx = SourceX + 140;
    var sy = SourceY + 30;
    var tx = TargetX;
    var ty = TargetY + 30;

    var dx = Math.Abs(tx - sx) * 0.5;
    var path = FormattableString.Invariant($"M {sx} {sy} C {sx + dx} {sy}, {tx - dx} {ty}, {tx} {ty}");
}

<g class="connection-group @(IsSelected ? "selected" : "")" @onclick="OnSelect" @onclick:stopPropagation="true">
    <path d="@path" class="connection-line-hit" fill="none" stroke="transparent" stroke-width="12" />
    <path d="@path" class="connection-line" fill="none"
          stroke="@(IsSelected ? "#0d6efd" : "#666")"
          stroke-width="@(IsSelected ? 3 : 2)"
          marker-end="url(#arrowhead)" />

    @if (!string.IsNullOrEmpty(Connection.Condition))
    {
        var mx = (sx + tx) / 2;
        var my = (sy + ty) / 2;
        var mxStr = mx.ToString(CultureInfo.InvariantCulture);
        var myStr = (my - 8).ToString(CultureInfo.InvariantCulture);
        @((MarkupString)$"<text x=\"{mxStr}\" y=\"{myStr}\" class=\"connection-label\" text-anchor=\"middle\">{Connection.Condition}</text>")
    }
</g>

@code {
    [Parameter, EditorRequired] public Workflow.Engine.Models.Connection Connection { get; set; } = default!;
    [Parameter] public double SourceX { get; set; }
    [Parameter] public double SourceY { get; set; }
    [Parameter] public double TargetX { get; set; }
    [Parameter] public double TargetY { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public EventCallback OnSelect { get; set; }
}
